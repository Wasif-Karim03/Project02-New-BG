# Copy to .env and fill in. The .env file is gitignored; this example is committed.
# Everything here is provider-agnostic: no cloud-vendor SDKs or vendor-specific keys.

# ── Database ─────────────────────────────────────────────────────────────────
# A PLAIN Postgres connection string is the ONLY database config. Local dev uses a
# disposable Postgres (Docker `docker compose up -d`, or a local Homebrew/native
# instance). Production swaps this URL for the client's own cloud Postgres at
# Phase H — no code changes required.
DATABASE_URL="postgresql://bridging_ops:bridging_ops@localhost:5432/bridging_ops_dev?schema=public"
# DIRECT (unpooled) connection used by Prisma migrations. Locally it's the same as
# DATABASE_URL; on Neon it's the non-pooler host (DATABASE_URL is the -pooler host).
DIRECT_URL="postgresql://bridging_ops:bridging_ops@localhost:5432/bridging_ops_dev?schema=public"

# ── Auth.js (NextAuth v5) ────────────────────────────────────────────────────
# Generate a real secret with: openssl rand -base64 32
AUTH_SECRET="change-me"
# In production set this to the deployed origin, e.g. https://admin.bridginggenerations.org
AUTH_URL="http://localhost:3000"

# ── File storage — Cloudflare R2 (S3-compatible) ─────────────────────────────
# Leave these BLANK for local dev / CI: files fall back to a gitignored ./uploads
# dir. Set all four in production so uploads persist (serverless disk is ephemeral).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# ── Production admin bootstrap ───────────────────────────────────────────────
# Used by `prisma db seed` to create the first ADMIN. REQUIRED (strong, 12+ chars)
# when seeding a real database; omit locally to use the dev default.
SEED_ADMIN_EMAIL="admin@bridginggenerations.org"
SEED_ADMIN_PASSWORD=""

# ── Stripe (Phase D onward) ──────────────────────────────────────────────────
# Empty in early phases. Set live keys + the signing secret when wiring webhooks.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Transactional email ──────────────────────────────────────────────────────
# Delivery backend, chosen in order: RESEND_API_KEY (Resend HTTP API, recommended
# on serverless) → EMAIL_SERVER (any SMTP URL) → neither (dev: printed to console).
# EMAIL_FROM must be on a domain verified with the provider.
EMAIL_FROM="no-reply@bridginggenerations.local"
RESEND_API_KEY=""
EMAIL_SERVER=""

# ── Free donation flow (no Stripe) ───────────────────────────────────────────
# Payment channels shown on the public /give page. Set the org's real numbers;
# leave blank to hide a channel. Public (client-visible) by design.
NEXT_PUBLIC_PAY_BKASH=""
NEXT_PUBLIC_PAY_NAGAD=""
NEXT_PUBLIC_PAY_ROCKET=""
NEXT_PUBLIC_PAY_BANK=""

# ── Marketing site (for the "Website content" hub → Keystatic) ────────────────
# Origin of the public marketing site; its Keystatic editor lives at /keystatic.
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"

# ── Scheduled jobs (Vercel Cron) ─────────────────────────────────────────────
# Secures the year-end auto-deactivation cron (/api/cron/year-end). Set a strong
# value in production; Vercel injects it as `Authorization: Bearer $CRON_SECRET`
# on scheduled runs. Requests without it are rejected 401 (the endpoint fails
# closed if this is unset). The manual admin button in Settings needs no secret.
CRON_SECRET=""
