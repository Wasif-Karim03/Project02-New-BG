// =============================================================================
// Bridging Generations — Phase 2 Operational Schema (canonical, migration-ready)
// PostgreSQL + Prisma. This is the source of truth for FACTS, MONEY, and PII.
// The public Next.js + Keystatic site is a SEPARATE store (narrative) and only
// ever receives a one-way, consent-filtered projection (see PUBLIC_PROJECTION.md).
//
// Key decisions encoded here:
//   * Identity is split: `User` = login/auth; Donor/Mentor/Student = profiles
//     that may exist WITHOUT a login (guest donor, admin/mentor-created student).
//   * Approval workflow: User.status and Student.status both carry PENDING; every
//     join path (student self-signup, mentor-registered student, donor signup)
//     funnels into the same admin queue. Admin-created records auto-approve.
//   * Money is INTEGER MINOR UNITS + ISO currency. Never floats.
//   * CURRENCY (v1): USD-ONLY. The `currency` columns are retained for forward
//     compatibility, but the boundary REJECTS any non-USD write, and every
//     computed aggregate (fundingRaised, totalRaised, …) ASSUMES a single
//     currency — minor units are summed directly and must not mix currencies.
//   * Stripe-sourced donations are written by webhook and their financial fields
//     are treated as IMMUTABLE in the service layer. Manual/cash/legacy rows are
//     admin-editable. Corrections are posted as adjustment rows, never silent edits.
//   * Webhook idempotency is event-level: every Stripe event is recorded in
//     `StripeEvent` (eventId @unique) before processing and skipped if already seen.
//   * Refunds: `Donation.refundedAmount` (minor units) holds refunded value.
//     Full refund => refundedAmount == amount AND status = REFUNDED; partial
//     refund => refundedAmount < amount AND status stays SUCCEEDED. Public totals
//     subtract refundedAmount, never the whole row.
//   * Recurring sponsorships via Stripe Subscriptions; each cycle creates a Donation.
//   * Tax receipts as a first-class entity (US 501(c)(3)).
//   * Legacy/offline data: source = LEGACY/CASH/etc. + isHistorical (suppresses
//     automations) but still counts toward computed public totals.
//   * Mentor access is row-scoped via MentorAssignment — enforced in the data layer.
//   * Project.fundingRaised / donor counts / totals are COMPUTED, never stored.
//   * Public slugs: Student.slug and Project.slug are unique, generated from a
//     human name + short random suffix, and IMMUTABLE once set. Student.slug is
//     null until the record is APPROVED (assigned at approval).
//   * `Session` (Auth.js web session) is distinct from `AcademicSession` (term).
//   * Some invariants Prisma can't express in-schema are enforced in the service
//     layer AND added as raw SQL in the migration: (a) a partial UNIQUE index on
//     AcademicSession(isCurrent) WHERE isCurrent = true; (b) a CHECK constraint on
//     Donation/Subscription tying designationType to studentId/projectId.
// =============================================================================

datasource db {
  provider = "postgresql"
  // Runtime uses the pooled connection (e.g. Neon's -pooler host). Migrations and
  // introspection use a DIRECT (unpooled) connection. Locally both point at the
  // same Postgres, so DIRECT_URL falls back to DATABASE_URL when unset.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  MENTOR
  DONOR
  STUDENT
}

enum AccountStatus {
  PENDING // awaiting admin approval
  ACTIVE
  SUSPENDED
  REJECTED
}

enum RecordStatus {
  DRAFT
  PENDING // awaiting admin approval (e.g. mentor-registered student)
  ACTIVE
  ARCHIVED
}

enum ConsentStatus {
  PENDING
  GRANTED
  DENIED
  REVOKED
}

enum ConsentScope {
  WEBSITE
  PRINT
  SOCIAL
}

enum DonationSource {
  STRIPE // written by webhook; financial fields immutable
  CASH // admin-entered offline
  CHECK
  BANK
  LEGACY // imported from the old website / historical
  OTHER
}

enum DonationStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  VOIDED
}

enum DesignationType {
  STUDENT
  PROJECT
  GENERAL
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  UNPAID
}

enum ProjectStatus {
  ACTIVE
  FUNDED
  PAUSED
}

// Public donor-wall listing state. A donor who opts in to be shown by name needs
// admin approval before appearing (PENDING → APPROVED / REJECTED). Anonymous or
// not-opted-in donors stay NONE and never appear by name (anonymous ones render
// as "Anonymous" on the wall; the rest simply aren't listed).
enum WallStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum ContactMethod {
  MOBILE
  EMAIL
  WHATSAPP
  IN_PERSON
  OTHER
}

enum ReceiptStatus {
  DRAFT
  ISSUED
  SENT
  FAILED
}

enum ApplicationStatus {
  DRAFT // being filled in
  SUBMITTED // submitted, awaiting email verification
  EMAIL_VERIFIED // verified, in the admin approval queue
  APPROVED
  REJECTED
}

enum PaymentType {
  ONE_TIME
  INSTALLMENT
}

enum TargetType {
  MONTH
  YEAR
}

// ---------------------------------------------------------------------------
// IDENTITY / AUTH
// `User` is the login. Role-specific profiles hang off it. Note that audit-ish
// FK fields (reviewedById, createdById, actorUserId) are stored as scalar user
// ids to avoid a forest of self-relations; they reference User.id logically.
// ---------------------------------------------------------------------------

model User {
  id                 String        @id @default(cuid())
  email              String        @unique
  name               String?
  role               Role          @default(DONOR)
  status             AccountStatus @default(PENDING)
  emailVerified      DateTime?
  // Self-service email verification (donor accounts): 6-digit code, stored hashed.
  emailCodeHash      String?
  emailCodeExpiresAt DateTime?
  image              String?
  // scrypt hash for email+password login (PRIMARY auth). Null = no password set
  // (magic-link-only / OAuth-only user). A SECRET: never projected, never logged,
  // never leaves the operational store.
  passwordHash       String?

  // approval audit (reviewedById references a User.id of an admin)
  reviewedById String?
  reviewedAt   DateTime?

  // role profiles (1-1, optional — a User has exactly one of these by role)
  donor              Donor?
  mentor             Mentor?
  student            Student?
  applications       StudentApplication[]
  mentorApplications MentorApplication[]

  // Auth.js adapter relations
  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([role])
}

// Auth.js (NextAuth) Prisma adapter models — WEB sessions, not academic terms.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Editable org configuration (payment channel numbers, org info) — key/value so
// staff can change what's shown publicly without a redeploy.
model OrgSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Self-service password reset. The raw token is emailed; only its hash is stored.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ---------------------------------------------------------------------------
// DONOR (giving identity — guest-capable: userId is nullable)
// ---------------------------------------------------------------------------

model Donor {
  id     String  @id @default(cuid())
  userId String? @unique // null = guest donor (no login); match to account later by verified email
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  name        String
  email       String?
  country     String?
  phone       String?
  avatarUrl   String? // optional profile picture (/api/files/...); public only once wallStatus=APPROVED
  isAnonymous Boolean @default(false) // controls public thank-you wall display
  // Public-wall listing state. Opted-in (named) donors are PENDING until an admin
  // approves them for the Donors page; anonymous donors stay NONE. The account
  // itself works regardless — this ONLY gates public visibility.
  wallStatus  WallStatus @default(NONE)
  wallMessage String? // optional message for the donor wall
  wallTier    String? // '', founder, patron, friend (mirrors existing site)

  donations     Donation[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ---------------------------------------------------------------------------
// MENTOR (always has a login; sees ONLY assigned students)
// ---------------------------------------------------------------------------

model Mentor {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  phone    String?
  bio      String?
  photoUrl String? // profile picture (from the application)

  assignments       MentorAssignment[]
  evaluations       StudentEvaluation[]
  mentorEvaluations MentorEvaluation[]
  applications      MentorApplication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Mentor application — mirrors StudentApplication: account → questions → email
// verification → admin approval → Mentor record. Field set is a sensible default
// (refined once the exact mentor questions are provided).
model MentorApplication {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentorId String?
  mentor   Mentor? @relation(fields: [mentorId], references: [id], onDelete: SetNull)

  status ApplicationStatus @default(DRAFT)

  emailCodeHash      String?
  emailCodeExpiresAt DateTime?
  emailVerifiedAt    DateTime?
  submittedAt        DateTime?
  reviewedById       String?
  reviewedAt         DateTime?

  // Profile / questions
  fullName     String?
  phone        String?
  profession   String?
  organization String?
  city         String?
  country      String?
  education    String?
  languages    String?
  experience   String? // teaching / mentoring background
  motivation   String? // why they want to mentor
  availability String? // e.g. hours per week
  howHeard     String?
  photoUrl     String? // profile picture — required to submit
  agreedTerms  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// SCHOOL
// ---------------------------------------------------------------------------

model School {
  id              String  @id @default(cuid())
  name            String
  slug            String  @unique
  location        String?
  description     String?
  establishedYear Int?
  heroImageUrl    String?

  students        Student[]
  studentSessions StudentSession[]

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// STUDENT (the sponsored person record — full PII; login optional)
// ---------------------------------------------------------------------------

model Student {
  id     String       @id @default(cuid())
  userId String?      @unique // null = admin/mentor-managed record with no login
  user   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  status RecordStatus @default(PENDING)

  // public-safe
  // Stable public key. Null until APPROVED; generated then from firstName + a
  // short random suffix (e.g. "rima-x7q2"), unique, and IMMUTABLE once set.
  // This is the key a Keystatic story uses to reference an operational student.
  slug       String?   @unique
  firstName  String
  // PII (never leaves the operational store)
  fullName   String?
  fatherName String?
  motherName String?
  // Bangla name variants — carried from the application (Bangla-first org / official docs).
  fullNameBn   String?
  fatherNameBn String?
  motherNameBn String?
  dob        DateTime?
  community  String?
  gender     String?

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  bio         String?
  quote       String?
  portraitUrl String?

  // consent (mirrors the existing Keystatic model so the bridge maps 1:1)
  portraitConsent  ConsentStatus  @default(PENDING)
  storyConsent     ConsentStatus  @default(PENDING)
  consentScopes    ConsentScope[]
  consentSignedAt  DateTime?
  releaseFormId    String?
  consentRevokable Boolean        @default(true)
  consentRevokedAt DateTime?

  enrolledAt   DateTime?
  isHistorical Boolean   @default(false) // imported from old site

  // Application-derived / admin ongoing record (S1+). PII — never projected.
  registrationId   String?      @unique
  isOrphan         Boolean      @default(false)
  ethnicity        String?
  fatherProfession String?
  motherProfession String?
  familyIncome     String?
  // Primary family contact — required on the application; carried so an admin always
  // has a way to reach the family (distinct from the optional guardian phone).
  familyMobile     String?
  addrVillage      String?
  // Detailed address parts — carried from the application (mentors do home visits).
  addrPara         String?
  addrPostOffice   String?
  addrThana        String?
  addrDistrict     String?
  guardianName     String?
  guardianMobile   String?
  guardianAddress  String?
  tutorName        String?
  tutorPhone       String?
  // Phase 4 admin-record additions (all nullable, additive)
  fatherPhone      String? // per-parent contact
  motherPhone      String?
  incomeSource     String? // source of income, distinct from familyIncome (the amount)
  selectionNote    String? // admin-only: why the selection team picked this student
  purpose          String?
  careerGoal       String?
  // Funding plan (money = integer MINOR UNITS, USD v1)
  paymentType      PaymentType?
  requireAmount    Int?
  minDonateAmount  Int?
  perInstallment   Int?
  targetType       TargetType?
  targetPeriod     String? // e.g. "2026" or "2026-01"
  verified         Boolean      @default(false)
  active           Boolean      @default(true)
  // Admin control: is this student shown in the public marketing site's student
  // directory? Defaults to true (approved students appear), admin can hide any.
  showOnWebsite    Boolean      @default(true)

  // creation/approval audit (ids reference User.id)
  createdById  String?
  reviewedById String?
  reviewedAt   DateTime?

  sessions          StudentSession[]
  evaluations       StudentEvaluation[]
  mentorEvaluations MentorEvaluation[]
  assignments       MentorAssignment[]
  donations     Donation[]
  subscriptions Subscription[]
  applications  StudentApplication[]
  installmentSeries InstallmentSeries[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([schoolId])
}

// ---------------------------------------------------------------------------
// STUDENT APPLICATION (the submitted scholarship form — full PII, never
// projected). Flows: DRAFT -> SUBMITTED (code emailed) -> EMAIL_VERIFIED (in the
// admin queue) -> APPROVED (maps into a Student + activates) / REJECTED.
// ---------------------------------------------------------------------------

model StudentApplication {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  status ApplicationStatus @default(DRAFT)

  // email verification (code is stored HASHED, never in plaintext)
  emailCodeHash      String?
  emailCodeExpiresAt DateTime?
  emailVerifiedAt    DateTime?

  // ক. Student info (bilingual)
  nameBn       String?
  nameEn       String?
  fatherNameBn String?
  fatherNameEn String?
  motherNameBn String?
  motherNameEn String?
  familyMobile String?
  gender       String?
  isOrphan     Boolean @default(false)
  ethnicity    String?
  dob          DateTime? // date of birth — mapped to Student.dob at approval (Phase 4)

  // খ. Education info
  schoolName           String?
  classNeeded          String?
  currentClass         String?
  roll                 String?
  totalStudents        String?
  favoriteSubject      String?
  favoriteSubjectMarks String?
  mathMarks            String?
  englishMarks         String?
  otherResults         Json? // [{subject, grade}]
  recentGovtExam       String?
  govtExamGrades       Json?
  careerGoal           String?
  hobbies              String?
  existingScholarship  Json? // {org, amount, type}
  scholarshipNeedFor   Json? // [fees, tuition, materials, other, note]

  // গ. Family & social
  addrVillage         String?
  addrPara            String?
  addrPostOffice      String?
  addrThana           String?
  addrDistrict        String?
  localGuardianName   String?
  localGuardianPhone  String?
  tutorName           String?
  tutorPhone          String?
  familyMembersMale   Int?
  familyMembersFemale Int?
  familyMembersTotal  Int?
  studyingChildren    String?
  monthlyFamilyIncome String?
  fatherProfession    String?
  fatherIncome        String?
  motherProfession    String?
  motherIncome        String?
  localKnownName      String?
  localKnownPhone     String?

  // agreements + uploaded files (URLs/keys; bytes live in storage, not the DB)
  agreedTerms    Boolean @default(false)
  // Guardian consent to display the student's photo publicly (watermarked). Gates
  // portraitConsent=GRANTED at approval; required to submit the application.
  photoConsent   Boolean @default(false)
  // Guardian consent to share the student's story/background publicly. Gates
  // storyConsent=GRANTED at approval (mirrors photoConsent). OPTIONAL — a family may
  // reasonably decline, so it is NOT in REQUIRED_CONSENTS.
  storyConsent   Boolean @default(false)
  // Discrete, individually-recorded agreements (Phase 3). Each is required to
  // submit and gated separately via REQUIRED_CONSENTS (same MissingFieldsError
  // pattern as the uploads). specialReason is an optional free-text note.
  consentVerificationCalls Boolean @default(false)
  consentMonthlyPayment    Boolean @default(false)
  consentMentorCheckins    Boolean @default(false)
  consentCancelPolicy      Boolean @default(false)
  specialReason            String?
  resultSheetUrl String?
  photoUrl       String?

  submittedAt     DateTime?
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// ACADEMIC SESSION (term/year) + per-session enrollment
// ---------------------------------------------------------------------------

model AcademicSession {
  id        String    @id @default(cuid())
  label     String    @unique // e.g. "2024-2025"
  startDate DateTime?
  endDate   DateTime?
  // At most one row may have isCurrent = true. Enforced in the service layer AND
  // by a partial UNIQUE index added in the migration SQL:
  //   CREATE UNIQUE INDEX "academic_session_one_current"
  //     ON "AcademicSession" ((isCurrent)) WHERE "isCurrent" = true;
  // (Prisma can't express a partial unique index in-schema.)
  isCurrent Boolean   @default(false)
  remarks   String?

  studentSessions   StudentSession[]
  assignments       MentorAssignment[]
  evaluations       StudentEvaluation[]
  mentorEvaluations MentorEvaluation[]
  donations         Donation[]
  installmentSeries InstallmentSeries[]
  // NOTE: no `subscriptions` back-relation. A recurring Subscription is a
  // donor-scoped, ongoing commitment that spans terms; per-cycle attribution to
  // a session lives on each Donation.sessionId, not on the Subscription.
  createdAt       DateTime            @default(now())
}

model StudentSession {
  id        String @id @default(cuid())
  studentId String
  sessionId String

  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  institutionName String? // school / college / university for this session
  grade           String? // class / grade no
  roll            String?
  formerRoll      String?
  totalStudent    String?
  degreeLevel     String? // optional BA/MA level — only meaningful when institution is a university (Phase 4)
  resultSheetUrl  String? // per-session result sheet (/api/files/...) — Phase 4
  amountNeeded    Int? // funding need for this student this session, in MINOR UNITS
  currency        String       @default("USD")
  status          RecordStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, sessionId])
  @@index([sessionId])
}

// ---------------------------------------------------------------------------
// MENTOR ASSIGNMENT (governs row-level access: a mentor may read a student
// ONLY when an active assignment exists). Scoped per session.
// ---------------------------------------------------------------------------

model MentorAssignment {
  id        String @id @default(cuid())
  mentorId  String
  studentId String
  sessionId String

  mentor  Mentor          @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  student Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session AcademicSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  assignedById String? // admin User.id
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?
  active       Boolean   @default(true)

  @@unique([mentorId, studentId, sessionId])
  @@index([studentId, active])
  @@index([mentorId, active])
}

// ---------------------------------------------------------------------------
// STUDENT EVALUATION (mentor-authored; access-scoped)
// ---------------------------------------------------------------------------

model StudentEvaluation {
  id        String  @id @default(cuid())
  studentId String
  sessionId String?
  mentorId  String

  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  mentor  Mentor           @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  evaluationType String?
  date           DateTime       @default(now())
  contactPerson  String?
  contactBy      ContactMethod?
  remarks        String?
  fileUrl        String?
  publishConsent Boolean        @default(false) // may this surface publicly?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([mentorId])
}

// ---------------------------------------------------------------------------
// MENTOR EVALUATION (Form 4 — the monthly evaluation the mentor fills for a
// student they are assigned to. Distinct from StudentEvaluation, which is the
// lighter contact/visit log. Written + read ONLY through the frozen mentor-access
// guard. Additive: this model is new; StudentEvaluation is untouched.)
// ---------------------------------------------------------------------------

enum SixPointRating {
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
  POOR
  VERY_POOR
}

// Overall progress grade. NOTE: the owner's source doc listed the bands as
// A/B/D/C with C at 1.7–2.5 and D at 2.5–3.4 — an ordering/overlap error. Corrected
// here to A(4.5–5.0), B(3.5–4.4), C(2.5–3.4), D(1.7–2.5), displayed A,B,C,D. The
// numeric bands live in PROGRESS_GRADE_BANDS (lib/validation/mentor-evaluation.ts).
enum ProgressGrade {
  A
  B
  C
  D
}

model MentorEvaluation {
  id        String  @id @default(cuid())
  studentId String
  sessionId String?
  mentorId  String

  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  mentor  Mentor           @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  date DateTime @default(now())

  // Identity header, snapshotted from Student/StudentSession at creation so the
  // evaluation is a stable historical record even if the live record later changes.
  studentName    String?
  mentorName     String?
  privateTeacher String?
  classGrade     String?
  currentRoll    String?
  formerRoll     String?
  institution    String?

  // Bangla study-habit questions as a structured list so questions can be added
  // later without a migration: [{ question, answer: "yes"|"no"|null, comment }].
  studyHabits Json?

  // Two 6-point ratings.
  participation       SixPointRating?
  parentCommunication SixPointRating?

  // Overall progress grade (A/B/C/D — see the ProgressGrade comment above).
  progressGrade ProgressGrade?

  // Per-subject progress notes as a structured list: [{ subject, note }].
  subjectNotes Json?

  overallEvaluation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([mentorId])
}

// ---------------------------------------------------------------------------
// PROJECT (fundingRaised is COMPUTED from succeeded donations — not stored)
// ---------------------------------------------------------------------------

model Project {
  id             String        @id @default(cuid())
  title          String
  // Generated from title + short random suffix, validated unique, immutable once
  // set (same convention as Student.slug). Required at creation (projects are
  // admin-created and public immediately, so there is no PENDING slug-less state).
  slug           String        @unique
  summary        String?
  body           String?
  fundingGoal    Int // minor units
  currency       String        @default("USD")
  status         ProjectStatus @default(ACTIVE)
  boardOwnerName String?
  displayOrder   Int?
  heroImageUrl   String?
  lastUpdated    DateTime?

  donations     Donation[]
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// DONATION (unified ledger: online Stripe rows + offline/legacy admin rows)
// ---------------------------------------------------------------------------

model Donation {
  id      String @id @default(cuid())
  donorId String
  donor   Donor  @relation(fields: [donorId], references: [id])

  // Invariant (Zod/service + raw-SQL CHECK in migration):
  //   STUDENT => studentId set,  projectId null
  //   PROJECT => projectId set,  studentId null
  //   GENERAL => studentId null, projectId null
  designationType DesignationType
  studentId       String?
  projectId       String?
  sessionId       String?

  student Student?         @relation(fields: [studentId], references: [id], onDelete: SetNull)
  project Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  session AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  amount    Int // MINOR UNITS
  currency  String         @default("USD") // v1: USD only, rejected at the boundary otherwise
  feeAmount Int? // processor fee (minor units), Stripe rows only
  netAmount Int? // amount - fee (Stripe-reported balance fact, not a public aggregate)
  source    DonationSource
  status    DonationStatus @default(PENDING)

  // Refunded value in MINOR UNITS. 0 = not refunded. Partial refund:
  // 0 < refundedAmount < amount, status stays SUCCEEDED. Full refund:
  // refundedAmount == amount, status = REFUNDED. Public totals use
  // (amount - refundedAmount) for SUCCEEDED rows.
  refundedAmount Int @default(0)

  // Stripe linkage (immutable once set; webhook-written)
  stripePaymentIntentId String? @unique
  stripeChargeId        String?
  idempotencyKey        String? @unique

  isRecurring    Boolean       @default(false)
  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  isHistorical Boolean  @default(false) // legacy/backfill — suppresses automations
  occurredAt   DateTime // the gift date (historical date for legacy rows)
  note         String?

  // Optional tribute / dedication ("in honor of" or "in memory of" someone).
  // tributePublic controls whether it may appear on a public tribute wall.
  tributeType     String? // "honor" | "memory"
  tributeName     String?
  tributeMessage  String?
  tributeImageUrl String?
  tributePublic   Boolean @default(false)

  // manual-entry / correction audit
  createdById  String? // admin User.id for offline/legacy rows
  voidedById   String?
  voidedReason String?
  voidedAt     DateTime?

  // adjustment chain (post a correction instead of editing a settled row)
  correctionOfId String?
  correctionOf   Donation?  @relation("Corrections", fields: [correctionOfId], references: [id])
  corrections    Donation[] @relation("Corrections")

  receipt Receipt?
  // Optional back-link: an installment (in a monthly award series) MAY reference the
  // real Donation that settled it. Additive overlay — a Donation is never required
  // to have an installment, and this never affects money aggregation.
  installment Installment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([donorId])
  @@index([studentId])
  @@index([projectId])
  @@index([status])
  @@index([source])
  @@index([occurredAt])
}

// ---------------------------------------------------------------------------
// SUBSCRIPTION (recurring sponsorship via Stripe; each cycle -> a Donation)
// ---------------------------------------------------------------------------

model Subscription {
  id      String @id @default(cuid())
  donorId String
  donor   Donor  @relation(fields: [donorId], references: [id])

  stripeSubscriptionId String? @unique

  status          SubscriptionStatus @default(ACTIVE)
  // Same designation invariant as Donation (Zod/service + raw-SQL CHECK):
  //   STUDENT => studentId set/projectId null; PROJECT => projectId set/studentId
  //   null; GENERAL => both null.
  designationType DesignationType
  studentId       String?
  projectId       String?

  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  amount   Int // per-cycle, minor units
  currency String @default("USD")
  interval String @default("month")

  currentPeriodEnd DateTime?
  canceledAt       DateTime?

  donations Donation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([donorId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// RECEIPT (501(c)(3) acknowledgment; one per settled donation)
// ---------------------------------------------------------------------------

model Receipt {
  id         String   @id @default(cuid())
  donationId String   @unique
  donation   Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  receiptNumber String        @unique
  issuedAt      DateTime?
  amount        Int
  currency      String        @default("USD")
  donorName     String?
  donorEmail    String?
  pdfUrl        String?
  sentAt        DateTime?
  status        ReceiptStatus @default(DRAFT)

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// STRIPE EVENT LEDGER (event-level webhook idempotency). Every incoming Stripe
// event is recorded here (after signature verification) BEFORE its side effects
// run; a replayed event whose id already exists is acknowledged and skipped.
// Donation/Subscription rows keep their own @unique keys as a second guard.
// ---------------------------------------------------------------------------

model StripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique // Stripe event.id (evt_…)
  type        String // e.g. "checkout.session.completed", "charge.refunded"
  processedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([type])
}

// ---------------------------------------------------------------------------
// AUDIT LOG (the "data tracking" requirement: approvals, voids, adjustments,
// manual entries, sensitive reads). actorUserId references User.id.
// ---------------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String // e.g. "donation.void", "student.approve", "evaluation.read"
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  reason      String?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// INSTALLMENT SERIES (Phase 7) — a yearly scholarship award paid in monthly
// installments via the LIVE mobile-banking path (bKash/Nagad/Rocket), NOT Stripe.
// This is an ADDITIVE tracking layer ON TOP of the frozen money model: it never
// mints or mutates Donation rows and never participates in money aggregation.
// Marking an installment paid records the fact (a timestamp + optional txn ref)
// and MAY reference the real Donation that settled it. Progress ("N of 12 paid,
// next due <month>") is derived by reading the installment rows.
// ---------------------------------------------------------------------------

model InstallmentSeries {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Optional tie to the academic year this award covers (informational).
  sessionId String?
  session   AcademicSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Human label for the award year, e.g. "2026 monthly award". One per student.
  label          String
  totalAmount    Int    // yearly award total, MINOR UNITS (USD v1)
  perInstallment Int    // default amount per monthly installment, MINOR UNITS
  currency       String @default("USD")

  installments Installment[]

  createdById String? // admin User.id who created the series
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, label]) // idempotent create: one series per student per label
  @@index([studentId])
}

model Installment {
  id       String            @id @default(cuid())
  seriesId String
  series   InstallmentSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  index    Int    // 1-based position within the series (1..N)
  dueMonth String // "YYYY-MM" — the month this installment is due (for "next due")
  amount   Int    // MINOR UNITS (USD v1); usually the series perInstallment

  // Paid state: paidAt null = outstanding. Idempotent — marking an already-paid
  // installment keeps the original paidAt and never double-applies (no money moves).
  paidAt DateTime?
  txnRef String? // OPTIONAL bKash/Nagad/Rocket transaction id, per installment
  method String? // optional channel: "bkash" | "nagad" | "rocket" | ...

  // OPTIONAL link to the real Donation that settled this installment.
  donationId String?   @unique
  donation   Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)

  markedById String? // admin User.id who marked it paid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([seriesId, index]) // one row per position; safe re-marking
  @@index([seriesId])
}
